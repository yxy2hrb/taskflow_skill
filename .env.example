# Copy to .env in this directory (same folder as SKILL.md / README.md):
#   cp .env.example .env
#
# Required for all LLM stages (preprocess, blueprint, state-model, component-codegen, page-layer --llm).

DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Preprocess also accepts QWEN_API_KEY as an alias for DASHSCOPE_API_KEY.
# OPENAI_API_KEY is also accepted by all LLM stages.
# QWEN_API_KEY=

# Model names — configure for your provider; scripts never hardcode these.
TEXT_MODEL=your-text-model
VISION_MODEL=your-vision-model
MODEL_TEMPERATURE=0
MODEL_SEED=42
