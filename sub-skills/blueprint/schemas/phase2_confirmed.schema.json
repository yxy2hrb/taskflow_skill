{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["action", "phase", "states"],
  "properties": {
    "action": { "const": "confirmed" },
    "phase": { "const": 2 },
    "states": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "label", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^state_[0-9]+$" },
          "label": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
